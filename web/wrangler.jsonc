{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "kantacky-calendar-web",
	"main": "./.cloudflare/worker.js",
	"site": {
		"bucket": "./.cloudflare/public"
	},
	"build": {
		"command": "bun run buf:generate && bun run build"
	},
	"compatibility_date": "2026-06-28",
	"vars": {
		"PUBLIC_API_BASE_URL": "https://api.calendar.kantacky.com"
	}
}
